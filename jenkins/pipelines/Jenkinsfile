pipeline {
    agent any

    environment {
        SERVICE_NAME = 'user-service'
        IMAGE_TAG = "v${BUILD_NUMBER}"
    }

    stages {
        stage('Checkout') {
            steps {
                echo "📥 Pulling code from GitHub..."
                checkout scm
                echo "✅ Code checked out successfully"
            }
        }

        stage('Install Tools') {
            steps {
                echo "🔧 Installing required tools..."
                sh '''
                    # Install kubectl
                    curl -sLO "https://dl.k8s.io/release/v1.28.0/bin/linux/amd64/kubectl"
                    chmod +x kubectl
                    mv kubectl /usr/local/bin/ 2>/dev/null || export PATH=$PWD:$PATH

                    # Install Trivy
                    curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b . latest

                    echo "✅ Tools installed"
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                dir("microservices/${SERVICE_NAME}") {
                    withSonarQubeEnv('SonarQube') {
                        sh '''
                            echo "🔍 Installing SonarQube Scanner..."
                            curl -sL https://binaries.sonarsource.com/Distribution/sonar-scanner-cli/sonar-scanner-cli-5.0.1.3006-linux.zip -o scanner.zip
                            jar xf scanner.zip
                            chmod +x sonar-scanner-5.0.1.3006-linux/bin/sonar-scanner

                            echo "🔍 Running SonarQube Analysis on user-service..."
                            ./sonar-scanner-5.0.1.3006-linux/bin/sonar-scanner \
                              -Dsonar.projectKey=user-service \
                              -Dsonar.projectName="User Service" \
                              -Dsonar.sources=. \
                              -Dsonar.exclusions=node_modules/**,sonar-scanner*/** \
                              -Dsonar.host.url=$SONAR_HOST_URL \
                              -Dsonar.token=$SONAR_AUTH_TOKEN
                        '''
                    }
                }
                echo "✅ SonarQube analysis complete - check results at SonarQube UI!"
            }
        }

        stage('Trivy Security Scan') {
            steps {
                echo "🔒 Scanning source code for vulnerabilities..."
                sh """
                    ./trivy fs --scanners vuln,secret --severity HIGH,CRITICAL \
                      --exit-code 0 \
                      microservices/${SERVICE_NAME}/
                """
                echo "✅ Security scan complete!"
            }
        }

        stage('Deploy to Kubernetes') {
            steps {
                echo "☸️ Deploying to Kubernetes..."
                sh """
                    export PATH=\$PWD:\$PATH
                    kubectl get pods -n devsecops-apps -l app=${SERVICE_NAME} --no-headers
                    echo "✅ Current deployment verified"
                    
                    # Restart deployment to pick up latest
                    kubectl rollout restart deployment/${SERVICE_NAME} -n devsecops-apps
                    kubectl rollout status deployment/${SERVICE_NAME} -n devsecops-apps --timeout=60s
                """
                echo "✅ Deployed to Kubernetes!"
            }
        }

        stage('Health Check') {
            steps {
                echo "🏥 Verifying service health..."
                sh '''
                    export PATH=$PWD:$PATH
                    kubectl exec -n devsecops-apps deploy/gateway-service -- \
                      wget -qO- http://user-service:3001/health
                '''
                echo ""
                echo "✅ Health check passed!"
            }
        }
    }

    post {
        success {
            echo "╔═══════════════════════════════════════════╗"
            echo "║  ✅ PIPELINE SUCCESS                      ║"
            echo "║  Service: ${SERVICE_NAME}                 ║"
            echo "║  Build: #${BUILD_NUMBER}                  ║"
            echo "╚═══════════════════════════════════════════╝"
        }
        failure {
            echo "❌ PIPELINE FAILED for ${SERVICE_NAME}"
        }
    }
}
